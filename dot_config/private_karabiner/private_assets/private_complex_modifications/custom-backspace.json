{
  "title": "Caps Lock + H = Backspace (RU only)",
  "rules": [
    {
      "description": "Caps Lock + H sends Backspace (only in Russian layout)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": ["left_control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "delete_or_backspace"
            }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                {
                  "language": "ru"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
